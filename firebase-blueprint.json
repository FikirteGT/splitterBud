{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "Workspace": {
      "title": "Workspace",
      "description": "A shared expense space for two people",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "joinCode": { "type": "string" },
        "members": { "type": "array" },
        "membersList": { "type": "object" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "joinCode", "members"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A shared expense entry",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "paidBy": { "type": "string" },
        "expenseDate": { "type": "string", "format": "date" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "paidBy", "expenseDate", "creatorId"]
    },
    "WeeklyPeriod": {
      "title": "Weekly Period",
      "description": "Settlement tracking for a specific week",
      "type": "object",
      "properties": {
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "isSettled": { "type": "boolean" },
        "settledAt": { "type": "string", "format": "date-time" },
        "settledBy": { "type": "string" }
      },
      "required": ["startDate", "endDate", "isSettled"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Activity notifications",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["type", "message", "isRead", "createdAt"]
    },
    "JoinCode": {
      "title": "Join Code",
      "description": "Lookup for workspace invitation codes",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" }
      },
      "required": ["workspaceId"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/workspaces/{workspaceId}": { "schema": "Workspace", "description": "Main workspace document" },
    "/workspaces/{workspaceId}/expenses/{expenseId}": { "schema": "Expense", "description": "Expenses under a workspace" },
    "/workspaces/{workspaceId}/periods/{periodId}": { "schema": "WeeklyPeriod", "description": "Weekly settlement periods" },
    "/users/{userId}/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/joinCodes/{code}": { "schema": "JoinCode", "description": "Invite code registry" }
  }
}
